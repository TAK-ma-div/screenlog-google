# --- AI 分析プロバイダ ---
# 保存(Sheets/Docs)・通知(Gmail)は常に Google。AI分析だけ選べます:
#   gemini     : Gemini API（GEMINI_BACKEND で AI Studio / Vertex を切替）
#   gemini_cli : gemini CLI 経由（※個人無料枠は現在不可）
#   openai     : OpenAI GPT（要 OPENAI_API_KEY・`pip install -r requirements-openai.txt`）
AI_PROVIDER=gemini

# --- AI (Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CLI_TIMEOUT_SECONDS=120

# Geminiバックエンド: aistudio（既定/APIキー・無料枠あり）か vertex（Vertex AI）
#  vertex = 送信データが学習に使われない（エンタープライズ保護）。要 Google Cloud 課金。
#  認証は ADC（gcloud auth application-default login など）。GEMINI_API_KEY は不要。
GEMINI_BACKEND=aistudio
# vertex のとき必須: Google Cloud プロジェクトID
GOOGLE_CLOUD_PROJECT=
# vertex のリージョン（例: global / us-central1 / asia-northeast1）
GOOGLE_CLOUD_LOCATION=global

# --- OpenAI (AI_PROVIDER=openai のとき) ---
# OpenAI API は既定で送信データを学習に使わない（安価・APIキーのみで設定簡単）。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Azure OpenAI / 互換エンドポイントを使う場合のみ設定（任意）
OPENAI_BASE_URL=

# --- Google (Sheets / Gmail) ---
# OAuthクライアントのcredentials.jsonをこのフォルダに置き、初回実行でtoken.jsonを生成。
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
# setup_sheet.py で作成後に表示されるIDを設定
SHEET_ID=
SHEET_TAB=log
# 通知メールの宛先（空なら自分のアカウント宛 = "me"）
GMAIL_TO=

# --- Capture ---
CAPTURE_INTERVAL_MINUTES=5
SCREENSHOT_DIR=screenshots
SAVE_SCREENSHOTS=true
# サンドボックス/CIではダミー画像を使う
USE_DUMMY_CAPTURE=false
# 古いスクショの自動削除（日数。0以下で無効）
SCREENSHOT_RETENTION_DAYS=14

# --- Window tracker (任意・既定オフ) ---
# 有効にするとアクティブウィンドウ名/アプリ名をGeminiに渡し分析精度を上げる（PRIVACY.md参照）
ENABLE_WINDOW_TRACKER=false
# アクティブウィンドウのサンプリング間隔（秒）
WINDOW_POLL_INTERVAL_SEC=30

# --- Logging ---
LOG_FILE=screenlog.log
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# --- API retry ---
API_RETRY_ATTEMPTS=3
API_RETRY_BASE_DELAY=1.0

# --- Filters / Notification ---
CONFIDENCE_THRESHOLD=70
# 低確信度のとき確認依頼メールを送るか
NOTIFY_ENABLED=true

# --- Categories / Columns（カスタマイズ） ---
# 業務分類。カンマ区切りで自由に定義（空なら既定の分類を使用）
CATEGORIES=
# Sheetsに記録する任意列（カンマ区切り。コア列 timestamp/summary/category/confidence/duration_min は常時記録）
# 選択肢: primary_screen,visible_output,focus_risk,non_productive_signal,screenshot_path,app_breakdown
RECORD_OPTIONAL_COLUMNS=primary_screen,visible_output,focus_risk,non_productive_signal,screenshot_path,app_breakdown

# --- Redaction (機密マスク) ---
# OCR+正規表現の決定的レイヤーを使う（rapidocr-onnxruntime 未導入なら自動スキップ）
USE_OCR_REDACTION=true
# マスク領域に足す余白（画像幅/高さに対する%）
REDACTION_PAD_PCT=1.5
# マスク方式: fill=黒塗り（復元不可・推奨） / blur=ぼかし
MASK_STYLE=fill

# --- Dev/sandbox ---
# true のとき Google API を呼ばずスタブ動作（実認証不要）
GOOGLE_STUB=false
